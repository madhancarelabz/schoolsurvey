    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO responses (session_id, question_id, selected_option, category, score, confirmed)\nSELECT $1::uuid, $2, $3::int, $4, $5::int, TRUE\nWHERE $2 != 'INIT'\nON CONFLICT (session_id, question_id)\nDO UPDATE SET \n    selected_option = EXCLUDED.selected_option, \n    category = EXCLUDED.category,\n    score = EXCLUDED.score,\n    confirmed = TRUE,\n    answered_at = NOW();",
        "options": {
          "queryReplacement": "=={{ $(\"Postgres: Fetch Session\").first().json.session_id }}, {{ $(\"Code: Parse Tool Args\").first().json.question_id }}, {{ $(\"Code: Parse Tool Args\").first().json.answer }}, {{ $(\"Get row(s) in sheet\").all().find(q => q.json.question_id === $(\"Code: Parse Tool Args\").first().json.question_id)?.json.category || 'Unknown' }}, {{ ($(\"Code: Parse Tool Args\").first().json.answer || 0) - 1 }}"
        }
