        "jsCode": "// === CHATWOOT CONFIGURATION ===\nconst API_TOKEN = 'MJxWqHUBFJNvRaR1v6bBA8wE';\nconst ACCOUNT_ID = '153238';\nconst INBOX_ID = '97309';\nconst BASE_URL = `https://app.chatwoot.com/api/v1/accounts/${ACCOUNT_ID}`;\nconst reqHeaders = { 'Content-Type': 'application/json', 'api_access_token': API_TOKEN };\n\n// === GET DATA FROM PREVIOUS NODES ===\nconst session = $node[\"Postgres: Fetch Session\"].json;\nconst scores = $node[\"Postgres: Compute Final Scores\"].json;\nconst employeeId = session.employee_id;\nconst role = session.role;\nconst sessionId = session.session_id;\n\ntry {\n  // 1. SEARCH for existing contact by identifier (prevents 422 duplicate error)\n  let contactId;\n  try {\n    const searchResult = await this.helpers.httpRequest({\n      method: 'GET',\n      url: `${BASE_URL}/contacts/search`,\n      headers: reqHeaders,\n      qs: { q: String(employeeId), include_contacts: 'true' },\n    });\n    // Find contact with matching identifier\n    const existing = searchResult.payload?.find(c => c.identifier === String(employeeId));\n    if (existing) {\n      contactId = existing.id;\n    }\n  } catch (searchErr) {\n    // Search failed, will try to create below\n  }\n\n  // 2. CREATE contact only if not found\n  if (!contactId) {\n    const contact = await this.helpers.httpRequest({\n      method: 'POST',\n      url: `${BASE_URL}/contacts`,\n      headers: reqHeaders,\n      body: { name: `Employee ${employeeId}`, identifier: String(employeeId) },\n    });\n    contactId = contact.payload?.contact?.id || contact.payload?.id;\n  }\n\n  // 3. Create Conversation\n  const convo = await this.helpers.httpRequest({\n    method: 'POST',\n    url: `${BASE_URL}/conversations`,\n    headers: reqHeaders,\n    body: { contact_id: contactId, inbox_id: parseInt(INBOX_ID) },\n  });\n  const convoId = convo.id;\n\n  // 4. Send Combined Report\n  const reportMsg = `📋 Survey Report\\n👤 Employee: ${employeeId}\\n🏷️ Role: ${role}\\n🔑 Session: ${sessionId}\\n📅 Date: ${new Date().toLocaleDateString('en-IN')}\\n\\n📊 Scores\\n🧠 Mindset: ${scores.mindset_score}\\n🔧 Toolset: ${scores.toolset_score}\\n🎯 Skillset: ${scores.skillset_score}\\n📈 Total: ${scores.total_score}\\n\\n💡 Summary & Recommendation\\n📝 ${scores.summary}\\n🎓 ${scores.recommendation}`;\n  await this.helpers.httpRequest({\n    method: 'POST',\n    url: `${BASE_URL}/conversations/${convoId}/messages`,\n    headers: reqHeaders,\n    body: { content: reportMsg, message_type: 'outgoing' },\n  });\n\n  // 5. Apply Labels\n  const scoreTag = scores.total_score >= 24 ? 'high-performer' : scores.total_score >= 12 ? 'moderate' : 'needs-training';\n  await this.helpers.httpRequest({\n    method: 'POST',\n    url: `${BASE_URL}/conversations/${convoId}/labels`,\n    headers: reqHeaders,\n    body: { labels: [role.toLowerCase(), scoreTag, 'ai-survey'] },\n  });\n\n  return [{ json: { chatwoot_status: 'pushed', conversation_id: convoId } }];\n\n} catch (error) {\n  return [{ json: { chatwoot_status: 'failed', error: error.message } }];\n}\n"
      },
